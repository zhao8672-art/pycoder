# PyCoder 环境变量配置文件
# 复制此文件为 .env 并修改配置

# ===== 应用配置 =====
APP_NAME=PyCoder
APP_VERSION=0.5.0
THEME=dark

# ===== 服务器配置 =====
# 端口号（对应 config/settings.py 中的 PYCODER_PORT）
PYCODER_PORT=8423

# ===== AI 模型配置 =====
# 各提供商 API Key（取消注释并填写）
# DEEPSEEK_API_KEY=your_deepseek_api_key
# OPENAI_API_KEY=your_openai_api_key
# ANTHROPIC_API_KEY=your_anthropic_api_key
# GOOGLE_API_KEY=your_google_api_key
# GROQ_API_KEY=your_groq_api_key
# OLLAMA_BASE_URL=http://localhost:11434

# ===== 安全配置（生产环境必须设置）=====
# JWT 签名密钥 — 启动时检查，未设置将使用随机临时密钥（重启后所有 Token 失效）
PYCODER_CLOUD_JWT_SECRET=
# API 访问密钥 — 控制 REST API 认证行为：
#   - 留空：自动生成临时 key（复用 ~/.pycoder/.api_key）
#   - 设置为具体值：强制认证，所有请求需携带 X-API-Key 头
#   - 设置为 'disabled'：完全关闭认证（仅开发用，启动时告警）
# 生产环境请显式设置一个强随机值，例如：
#   PYCODER_API_KEY=$(python -c "import secrets; print(secrets.token_urlsafe(32))")
PYCODER_API_KEY=

# ===== 日志配置 =====
LOG_LEVEL=INFO

# ===== 工作目录 =====
# PYCODER_WORKSPACE=/path/to/workspace
