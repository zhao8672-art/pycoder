{
    "name": "pycoder",
    "version": "0.5.0",
    "description": "PyCoder - Python 开发者原生的 AI 编程 IDE (Desktop)",
    "main": "dist/main/index.js",
    "author": "PyCoder Team",
    "license": "MIT",
    "appId": "com.pycoder.app",
    "scripts": {
        "dev": "npm run dev:simple",
        "dev:simple": "npm run build && npm run start:prod",
        "build": "npm run build:renderer && npm run build:main && npm run build:preload",
        "build:renderer": "vite build --config vite.config.ts",
        "build:main": "tsc -p tsconfig.main.json",
        "build:preload": "tsc -p tsconfig.preload.json",
        "start": "electron .",
        "start:prod": "electron .",
        "package": "electron-forge package",
        "make": "electron-forge make"
    },
    "dependencies": {
        "@monaco-editor/react": "^4.7.0",
        "@xterm/addon-fit": "^0.11.0",
        "@xterm/xterm": "^6.0.0",
        "monaco-editor": "^0.55.1",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-markdown": "^10.1.0",
        "remark-gfm": "^4.0.1",
        "zustand": "^5.0.14"
    },
    "devDependencies": {
        "@electron-forge/cli": "^7.7.0",
        "@electron-forge/maker-deb": "^7.7.0",
        "@electron-forge/maker-dmg": "^7.7.0",
        "@electron-forge/maker-rpm": "^7.7.0",
        "@electron-forge/maker-squirrel": "^7.7.0",
        "@electron-forge/maker-zip": "^7.7.0",
        "@electron-forge/plugin-fuses": "^7.7.0",
        "@types/react": "^19.1.10",
        "@types/react-dom": "^19.1.5",
        "concurrently": "^9.1.2",
        "cross-env": "^7.0.3",
        "electron": "^31.0.0",
        "typescript": "^5.8.3",
        "vite": "^6.3.5",
        "wait-on": "^8.0.3"
    }
}
